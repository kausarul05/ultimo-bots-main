          {
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Do I need to know how to code to use Ultimo Bots?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "No coding is needed. The onboarding flow is designed so anyone can create a powerful agentic AI assistant in about two minutes with clicks only."
                }
              },
              {
                "@type": "Question",
                "name": "What kind of customer requests can Ultimo Bots handle?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Ultimo Bots can run agentic workflows to book appointments, adjust subscription plans, answer account questions, troubleshoot customer device issues and route or escalate complex cases, depending on the tools and integrations you connect."
                }
              },
              {
                "@type": "Question",
                "name": "How fast is the setup compared to other AI tools?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Ultimo Bots focuses on the fastest setup on the market. In most cases, you can go from sign-up to a live agent on your website in around two minutes by entering your URL, testing the agent and embedding the widget."
                }
              },
              {
                "@type": "Question",
                "name": "How does Ultimo Bots reduce hallucinations?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Ultimo Bots uses multi-agent security protocols and source-first retrieval so answers are grounded in your content. When information is missing or unclear, the agent is guided to say it does not know or escalate, instead of inventing facts."
                }
              },
              {
                "@type": "Question",
                "name": "Is Ultimo Bots suitable for small businesses?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Ultimo Bots is especially attractive for small businesses because it offers advanced agentic AI features at very competitive prices, while many platforms with similar capabilities are significantly more expensive."
                }
              },
              {
                "@type": "Question",
                "name": "Can I train my assistant with my website, documents or FAQs?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Add your website URL, upload files such as PDF or simply add FAQs. The assistant learns from this content to answer questions and to automate customer service workflows."
                }
              },
              {
                "@type": "Question",
                "name": "How do I integrate the assistant into my site?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Use a single line embed code or the native apps for Wix and Webflow. The official WordPress plugin is also available for instant integration on WordPress."
                }
              },
              {
                "@type": "Question",
                "name": "Can I change how the assistant looks and behaves?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Ultimo Bots offers extensive design and behavior customisation. You can configure colors, logos, icon, position, welcome copy, tone of voice and task behavior so the agent matches your brand better than on most other platforms."
                }
              },
              {
                "@type": "Question",
                "name": "Is my data secure?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Data is hosted under strict European privacy expectations, with Swiss and GDPR-aligned practices. Your content is private, controlled by you and can be removed at any time."
                }
              },
              {
                "@type": "Question",
                "name": "Is there a free trial and onboarding support?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Ultimo Bots offers a free trial on all plans and free integration and setup calls so you can install the platform instantly and get help from the support team if needed."
                }
              },
              {
                "@type": "Question",
                "name": "How is customer support rated?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Ultimo Bots is consistently rated highly for its responsive and helpful support across platforms such as Wix, Webflow and WordPress, including free setup help and ongoing guidance."
                }
              },
              {
                "@type": "Question",
                "name": "Does Ultimo Bots work on mobile devices?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. The chat experience is responsive and smooth on desktop, tablet, smartphone and any other device."
                }
              },
              {
                "@type": "Question",
                "name": "Can the chatbot detect and respond in any language?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Ultimo Bots automatically detects the visitor’s language and responds fluently in it, so you can support customers in multiple markets from one assistant."
                }
              },
              {
                "@type": "Question",
                "name": "What counts as one message?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "One message equals a pair of user input and bot response. For example, when a visitor asks a question and the bot answers, that counts as one message."
                }
              },
              {
                "@type": "Question",
                "name": "I need help with integration.",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "We are happy to help and offer free integration and setup support. Book a session directly at https://calendly.com/build-ultimo-bots/integration_support."
                }
              },
              {
                "@type": "Question",
                "name": "Do I get notifications when the message limits run out?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. At 80 percent of your message limit, you will receive a notification and can easily buy additional messages if needed."
                }
              }
            ]
          }
        ]
      }
