(self.webpackChunk_N_E=self.webpackChunk_N_E||[]).push([[509],{5434:(n,e,t)=>{(window.__NEXT_P=window.__NEXT_P||[]).push(["/company",function(){return t(7448)}])},7448:(n,e,t)=>{"use strict";t.r(e),t.d(e,{default:()=>u});var s=t(7876),i=t(7328),o=t.n(i),a=t(4587),r=t.n(a),c=t(7460),l=t(1041),m=t(5105),p=t.n(m);function u(){return(0,s.jsxs)(s.Fragment,{children:[(0,s.jsx)(p(),{id:"company-structured-data",type:"application/ld+json",strategy:"afterInteractive",dangerouslySetInnerHTML:{__html:'\n      {\n        "@context": "https://schema.org",\n        "@graph": [\n          {\n            "@type": "WebPage",\n            "@id": "https://ultimo-bots.com/company/#webpage",\n            "url": "https://ultimo-bots.com/company",\n            "name": "About Us | Ultimo Bots",\n            "inLanguage": "en",\n            "description": "Learn about Ultimo Bots, the Swiss-based agentic AI platform for automated customer service. We build multi-agent AI assistants that handle complex customer requests, from bookings to subscription changes and troubleshooting, with fast setup and European precision.",\n            "isPartOf": {\n              "@type": "WebSite",\n              "@id": "https://ultimo-bots.com/#website",\n              "url": "https://ultimo-bots.com/",\n              "name": "Ultimo Bots"\n            },\n            "publisher": {\n              "@type": "Organization",\n              "@id": "https://ultimo-bots.com/#organization"\n            },\n            "mainEntity": {\n              "@type": "Organization",\n              "@id": "https://ultimo-bots.com/#organization"\n            }\n          },\n          {\n            "@type": "Organization",\n            "@id": "https://ultimo-bots.com/#organization",\n            "name": "Ultimo Bots",\n            "alternateName": "Agentic AI Customer Service Platform",\n            "url": "https://ultimo-bots.com",\n            "logo": "https://ultimo-bots.com/ultimo-bots-logo.png",\n            "image": "https://ultimo-bots.com/og-preview.png",\n            "description": "Ultimo Bots is a Swiss-based agentic AI platform focused on precise, reliable customer service automation. Businesses use Ultimo Bots to launch multi-agent AI assistants that can book appointments, adjust subscription plans and resolve customer issues through secure integrations in just a few minutes, without coding.",\n            "founder": {\n              "@type": "Person",\n              "@id": "https://ultimo-bots.com/#founder",\n              "name": "Robert Kl\xf6psch",\n              "jobTitle": "Founder & CEO",\n              "image": "https://ultimo-bots.com/Robert-Portrait.jpg",\n              "sameAs": [\n                "https://www.linkedin.com/in/robertkloepsch/"\n              ]\n            },\n            "location": {\n              "@type": "Place",\n              "address": {\n                "@type": "PostalAddress",\n                "streetAddress": "Stegmattstrasse 10",\n                "postalCode": "6033",\n                "addressLocality": "Buchrain",\n                "addressCountry": "CH"\n              }\n            },\n            "areaServed": [\n              {\n                "@type": "Country",\n                "name": "Switzerland"\n              },\n              {\n                "@type": "Country",\n                "name": "Germany"\n              },\n              {\n                "@type": "Country",\n                "name": "Austria"\n              },\n              {\n                "@type": "Country",\n                "name": "France"\n              },\n              {\n                "@type": "Country",\n                "name": "Italy"\n              },\n              {\n                "@type": "Country",\n                "name": "Other European countries"\n              }\n            ],\n            "brand": {\n              "@type": "Brand",\n              "name": "Ultimo Bots",\n              "logo": "https://ultimo-bots.com/ultimo-bots-logo.png"\n            },\n            "sameAs": [\n              "https://www.linkedin.com/company/ultimo-bots"\n            ],\n            "foundingDate": "2024",\n            "slogan": "Swiss-made agentic AI: fast setup, precise answers, trusted automation.",\n            "knowsAbout": [\n              "agentic AI",\n              "multi-agent workflows",\n              "customer service automation",\n              "subscription management automation",\n              "appointment booking automation",\n              "small business AI tools",\n              "multilingual chatbots",\n              "Webflow AI apps",\n              "Wix AI apps",\n              "WordPress AI plugins"\n            ]\n          },\n          {\n            "@type": "CreativeWork",\n            "@id": "https://ultimo-bots.com/company/#mission",\n            "about": {\n              "@type": "Thing",\n              "name": "Ultimo Bots Mission, Vision and Values"\n            },\n            "inLanguage": "en",\n            "headline": "Our Mission: Swiss-Grade Agentic AI for Every Business",\n            "text": "Ultimo Bots believes that every business, from small teams to growing brands, should have access to precise, trustworthy agentic AI. Our mission is to turn complex automation—such as bookings, subscription changes and troubleshooting—into a simple two-minute setup. We focus on Swiss-style quality, privacy-first design and multi-agent reliability so companies can automate customer service with confidence. Our core values are simplicity, accessibility, privacy-first, continuous improvement and long-term trust.",\n            "publisher": {\n              "@id": "https://ultimo-bots.com/#organization"\n            }\n          },\n          {\n            "@type": "Person",\n            "@id": "https://ultimo-bots.com/#founder",\n            "name": "Robert Kl\xf6psch",\n            "jobTitle": "Founder & CEO",\n            "image": "https://ultimo-bots.com/Robert-Portrait.jpg",\n            "worksFor": {\n              "@id": "https://ultimo-bots.com/#organization"\n            },\n            "sameAs": [\n              "https://www.linkedin.com/in/robertkloepsch/"\n            ]\n          },\n          {\n            "@type": "FAQPage",\n            "@id": "https://ultimo-bots.com/company/#faq",\n            "mainEntity": [\n              {\n                "@type": "Question",\n                "name": "What is Ultimo Bots\' vision?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Our vision is to be the go-to platform for agentic AI in customer service, giving every business a high-quality AI agent that can handle complex tasks such as bookings, subscription adjustments and troubleshooting with Swiss-grade precision."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "What is Ultimo Bots\' mission?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Our mission is to remove the technical and financial barriers to agentic AI adoption. We simplify multi-agent customer service automation into a fast, guided experience so that any team can launch a reliable AI agent in minutes, not weeks."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "Where is Ultimo Bots based?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Ultimo Bots is based in Switzerland, near Lucerne. Our Swiss roots shape our focus on precision, reliability and strong privacy standards aligned with European expectations."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "Who founded Ultimo Bots?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Ultimo Bots was founded by Robert Kl\xf6psch, an AI entrepreneur with more than a decade of experience in data science, optimization and intelligent automation for industry and services."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "What makes Ultimo Bots different from other chatbot platforms?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Ultimo Bots focuses on agentic AI, not just simple chat. Our platform runs multi-step workflows, integrates with tools like calendars and subscription systems, offers deep brand customisation and provides a very fast setup designed for businesses with no coding or AI background."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "Is Ultimo Bots suitable for small businesses?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Yes. Ultimo Bots is designed to be especially attractive for small and medium-sized businesses by combining powerful agentic AI features with competitive pricing and a simple onboarding flow."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "How can I try Ultimo Bots?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "You can start for free at https://portal.ultimo-bots.com, create your AI agent in a guided flow and integrate it on your site within a few minutes."\n                }\n              }\n            ]\n          }\n        ]\n      }\n          '}}),(0,s.jsxs)(o(),{children:[(0,s.jsx)("title",{children:"About Us | Ultimo Bots"}),(0,s.jsx)("meta",{name:"description",content:"Discover Ultimo Bots' mission to bring Swiss-made agentic AI to every business with fast setup, precise automation and privacy-first design."}),(0,s.jsx)("link",{rel:"canonical"