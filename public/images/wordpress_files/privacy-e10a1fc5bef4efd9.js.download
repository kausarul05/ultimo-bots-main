n              "streetAddress": "Stegmattstrasse 11",\n              "addressLocality": "Buchrain",\n              "postalCode": "6033",\n              "addressCountry": "Switzerland"\n            },\n            "contactPoint": {\n              "@type": "ContactPoint",\n              "contactType": "Data Protection Officer",\n              "email": "build@ultimo-bots.com",\n              "availableLanguage": "en"\n            },\n            "sameAs": [\n              "https://www.linkedin.com/company/ultimo-bots"\n            ]\n          },\n          {\n            "@type": "FAQPage",\n            "@id": "https://ultimo-bots.com/privacy/#faq",\n            "mainEntity": [\n              {\n                "@type": "Question",\n                "name": "Who operates Ultimo Bots?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Ultimo Bots is operated by Robert Kl\xf6psch, based in Buchrain, Switzerland."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "Which laws does Ultimo Bots comply with?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Ultimo Bots complies with the Swiss Federal Act on Data Protection (FADP) and the EU General Data Protection Regulation (GDPR)."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "What personal data does Ultimo Bots collect?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "We collect limited personal data from chatbot creators and visitors, such as email, usage logs, and messages, to operate and improve our platform."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "Does Ultimo Bots share personal data with third parties?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "We do not sell data. We may share information with trusted subprocessors such as Microsoft Azure, Stripe, and OpenAI for service delivery under GDPR-compliant agreements."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "How long is data retained?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Data is retained as long as necessary to fulfill the purposes of processing, comply with laws, and improve the platform."\n                }\n              },\n              {\n                "@type": "Question",\n                "name": "How can users exercise their data rights?",\n                "acceptedAnswer": {\n                  "@type": "Answer",\n                  "text": "Users can request access, correction, or deletion of their data. Chatbot creators may contact build@ultimo-bots.com to exercise their rights."\n                }\n              }\n            ]\n          }\n        ]\n      }\n          '}}),(0,s.jsxs)(o(),{children:[(0,s.jsx)("title",{children:"Privacy Policy | Ultimo Bots"}),(0,s.jsx)("meta",{name:"description",content:"Learn how Ultimo Bots collects, uses, and protects your personal data, in compliance with Swiss FADP and EU GDPR regulations."}),(0,s.jsx)("link",{rel:"canonical",href:"https://ultimo-bots.com/privacy"})]}),(0,s.jsxs)("div",{className:"legal-page",children:[(0,s.jsx)("h1",{children:"Privacy Policy"}),(0,s.jsxs)("p",{children:[(0,s.jsx)("strong",{children:"Last Updated:"})," 28.05.2025"]}),(0,s.jsx)("h2",{children:"1. Introduction"}),(0,s.jsxs)("p",{children:["Ultimo Bots is a software development project operated by Robert Kl\xf6psch, with the following address: Stegmattstrasse 11, 6033 Buchrain, Switzerland. For all inquiries, please contact ",(0,s.jsx)("strong",{children:"build@ultimo-bots.com"}),"."]}),(0,s.jsx)("p",{children:"This Priva